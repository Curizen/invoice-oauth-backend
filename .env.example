# --- App ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# 32-byte hex key for AES-256-GCM. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DEV ONLY. In production, replace src/crypto.ts key loading with
# envelope encryption via AWS KMS / GCP KMS / Vault Transit.
MASTER_KEY_HEX=replace-with-64-hex-chars-from-the-command-above

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/invoice_app

# --- Google (console.cloud.google.com -> APIs & Services -> Credentials) ---
# OAuth client type: "Web application"
# Authorized redirect URI: http://localhost:3000/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Microsoft (portal.azure.com -> App registrations) ---
# Supported account types: "Accounts in any organizational directory and personal Microsoft accounts"
# Redirect URI (Web): http://localhost:3000/callback/microsoft
# Certificates & secrets -> New client secret
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret

# --- Supabase (supabase.com -> your project -> Settings) ---
# DATABASE_URL above should be the Supabase connection string:
#   Settings -> Database -> Connection string -> use the SESSION pooler
#   (port 5432) URI, e.g.
#   postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Settings -> API:
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Single-user seed (Settings -> API -> service_role secret) ---
# This app is single-user: only the account created by
# `npm run db:seed-user` can ever log in (see src/supabaseAuth.ts). The
# service_role key is ONLY used by that one-off script — never read at
# app runtime, never sent to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SEED_USER_EMAIL=owner@example.com
SEED_USER_PASSWORD=replace-with-a-strong-password

# --- Internal API (n8n / background workers) ---
# Sent as the X-Internal-Key header on /internal/* routes.
INTERNAL_API_KEY=replace-with-a-long-random-string
# Optional comma-separated source-IP allowlist for /internal/*. When set,
# requests from other IPs get 403 before the key check. Leave empty if your
# n8n instance has no stable egress IP.
INTERNAL_ALLOWED_IPS=

# --- Auth fallback (dev only) ---
# demoAuth authenticates EVERY request as the demo user. The server refuses to
# start without SUPABASE_URL unless NODE_ENV=development AND this is true.
ALLOW_DEMO_AUTH=false

# --- Database TLS (production) ---
# Supabase CA certificate for verifying the DB server cert (Dashboard ->
# Settings -> Database -> SSL certificate). Provide the PEM (or base64 of it)
# inline, OR a file path. A copy of the public Supabase Root 2021 CA is
# committed at db/supabase-root-2021-ca.crt — cross-check it against the one
# in your dashboard, then set SUPABASE_CA_CERT_FILE=db/supabase-root-2021-ca.crt.
# If neither is set, the app logs a loud warning and connects WITHOUT
# certificate verification.
SUPABASE_CA_CERT=
SUPABASE_CA_CERT_FILE=

# --- Invoice pipeline (forward-looking; not yet implemented in this repo) ---
# Keep ENABLE_SYNC=false in production — the external n8n workflow is the
# active pipeline. Flipping this on would double-process every mailbox
# until the internal pipeline's column mapping is reconciled with the
# invoices table added by db/migration_002_invoices.sql.
ENABLE_SYNC=false
OPENAI_API_KEY=
BASE_CURRENCY=USD

# n8n "Multi-Currency Normalization" endpoint (Frankfurter historical rates)
N8N_NORMALIZE_WEBHOOK_URL=

# n8n "Contract Extractor via Webhook" endpoint
N8N_CONTRACT_WEBHOOK_URL=

# n8n "Smart Duplicate Detection" endpoint. Optional: falls back to the
# inline exact vendor+invoice_number match when unset or unreachable.
N8N_DUPLICATE_CHECK_WEBHOOK_URL=

# n8n "Vendor Intelligence" endpoint. Optional: falls back to the inline
# typical_amount deviation-% check when unset or unreachable.
N8N_VENDOR_INTEL_WEBHOOK_URL=
