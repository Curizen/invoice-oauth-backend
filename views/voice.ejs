<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head', { title: 'Voice Invoice' }) %>
<style>
  .content { padding-bottom: 7rem; max-width: 720px; }
  .intro { color: var(--subtitle); font-size: 0.9rem; line-height: 1.5; margin: 0 0 1.2rem; }
  #chat { display: flex; flex-direction: column; gap: 0.6rem; }
  .bubble {
    max-width: 80%; padding: 0.65rem 0.9rem; border-radius: 14px;
    font-size: 0.95rem; line-height: 1.45; white-space: pre-wrap; word-wrap: break-word;
  }
  .bubble.user { align-self: flex-end; background: var(--accent); color: #fff; border-bottom-right-radius: 4px; }
  .bubble.bot  { align-self: flex-start; background: #fff; border: 1px solid var(--card-border); border-bottom-left-radius: 4px; }
  .bubble.saved { align-self: flex-start; background: #e3f6ee; border: 1px solid #b7e2c8; color: #0b6f59; }
  .bubble.err  { align-self: flex-start; background: #fbe6e4; border: 1px solid #f3c2c2; color: #98211f; }
  .bubble.warn { align-self: flex-start; background: #fff4e5; border: 1px solid #f0d8b0; color: #8a5300; }
  .meta { font-size: 0.75rem; color: var(--subtitle); align-self: center; }

  .bubble.voice { display: flex; align-items: center; gap: 10px; min-width: 190px; padding: 8px 12px; }
  .voice-play {
    flex-shrink: 0; width: 30px; height: 30px; border-radius: 50%;
    background: rgba(255,255,255,0.22); border: none; color: #fff;
    display: flex; align-items: center; justify-content: center; cursor: pointer; padding: 0;
  }
  .voice-play:hover { background: rgba(255,255,255,0.32); }
  .voice-play svg { width: 13px; height: 13px; }
  .voice-progress {
    flex: 1; height: 4px; background: rgba(255,255,255,0.35); border-radius: 999px;
    position: relative; cursor: pointer;
  }
  .voice-progress-fill {
    position: absolute; left: 0; top: 0; bottom: 0; width: 0%;
    background: #fff; border-radius: 999px;
  }
  .voice-time {
    font-size: 11px; color: rgba(255,255,255,0.9); font-variant-numeric: tabular-nums;
    flex-shrink: 0; min-width: 34px; text-align: right;
  }

  .composer {
    position: fixed; bottom: 0; left: var(--sidebar-w); right: 0; background: #fff;
    border-top: 1px solid var(--card-border); padding: 0.7rem 1rem;
  }
  .composer-inner { max-width: 720px; margin: 0 auto; display: flex; gap: 0.5rem; align-items: center; }
  #text { flex: 1; padding: 0.7rem 0.9rem; border: 1px solid #ddd3bf; border-radius: 999px; font-size: 0.95rem; font-family: var(--font-body); }
  .composer button {
    border: none; border-radius: 999px; cursor: pointer; font-size: 0.95rem;
    padding: 0.7rem 1.1rem; background: var(--accent); color: #fff; font-family: var(--font-body); font-weight: 600;
  }
  .composer button:disabled { background: #d9d2c2; cursor: default; }
  #mic.recording { background: #d32f2f; animation: pulse 1s infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.6; } }

  .bubble.photo { padding: 6px; }
  .bubble.photo img { display: block; max-width: 220px; max-height: 280px; border-radius: 10px; }

  /* Camera capture modal */
  #camera-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 100;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 16px;
  }
  #camera-modal video, #camera-modal canvas { max-width: 100%; max-height: 70vh; border-radius: 8px; background: #000; }
  .camera-controls { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
  .camera-controls button {
    border: none; border-radius: 999px; cursor: pointer; font-size: 0.95rem;
    padding: 0.7rem 1.1rem; background: var(--accent); color: #fff; font-family: var(--font-body); font-weight: 600;
  }
  .camera-controls button.secondary { background: rgba(255,255,255,0.2); }

  @media (max-width: 860px) {
    .composer { left: 0; }
  }
</style>
</head>
<body>
<%- include('partials/shell-open') %>
      <div class="page-head">
        <div>
          <h1>Voice Invoice</h1>
          <p class="subtitle">Record or type an invoice and let the assistant fill in the rest.</p>
        </div>
      </div>
      <p class="intro">
        Tap the mic and say the invoice — e.g. <em>"Invoice from Acme for 500 dollars,
        dated today, category software."</em> Or type below. I'll ask for anything
        that's missing, then save it.
      </p>
      <div id="chat"></div>
<%- include('partials/shell-close') %>

  <div class="composer">
    <div class="composer-inner">
      <button id="mic" type="button" title="Record">●</button>
      <button id="camera" type="button" title="Photograph a receipt">📷</button>
      <input id="text" type="text" placeholder="Type an invoice or answer…" autocomplete="off" />
      <button id="send" type="button">Send</button>
    </div>
  </div>

  <!-- In-page camera capture: the photo goes through the /upload-invoice flow -->
  <div id="camera-modal" style="display:none">
    <video id="camera-video" autoplay playsinline muted></video>
    <canvas id="camera-canvas" style="display:none"></canvas>
    <div class="camera-controls">
      <button id="camera-capture" type="button">📸 Capture</button>
      <button id="camera-use" type="button" style="display:none">Use photo</button>
      <button id="camera-retake" type="button" class="secondary" style="display:none">Retake</button>
      <button id="camera-cancel" type="button" class="secondary">Cancel</button>
    </div>
  </div>

<script type="module" src="/js/voice.js"></script>
</body>
</html>
