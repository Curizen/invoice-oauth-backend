<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head', { title: 'Reports' }) %>
<style>
  .send { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; }
  .send select { padding: 9px 10px; border: 1px solid #ddd3bf; border-radius: 10px; font-size: 13.5px; }
</style>
</head>
<body>
<%- include('partials/shell-open') %>
      <div class="page-head">
        <div>
          <h1>Financial Reports</h1>
          <p class="subtitle" id="period-label">Spend summary across every connected mailbox.</p>
        </div>
      </div>

      <div class="tabs" id="tabs">
        <button class="tab active" data-period="monthly">Monthly</button>
        <button class="tab" data-period="quarterly">Quarterly</button>
        <button class="tab" data-period="yearly">Yearly</button>
      </div>

      <div class="stat-row" id="cards"></div>

      <div class="card"><h2>Top vendors</h2><div id="vendors"></div></div>
      <div class="card"><h2>By category</h2><div id="categories"></div></div>

      <div class="card send">
        <span class="muted-text">Email this report from:</span>
        <select id="acct"></select>
        <button id="send-btn" class="btn" type="button">Send</button>
        <span class="ok-text" id="send-status"></span>
      </div>
<%- include('partials/shell-close') %>

<script type="module" src="/js/reports.js"></script>
</body>
</html>
