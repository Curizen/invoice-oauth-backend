<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head', { title: 'Dashboard' }) %>
<style>
  /* Onboarding (zero connections) */
  #onboarding { max-width: 480px; margin: 4rem auto; text-align: center; }
  .ob-title { font-size: 22px; font-weight: 700; margin: 0 0 0.6rem; font-family: var(--font-heading); }
  .ob-text { color: var(--subtitle); font-size: 0.95rem; line-height: 1.5; margin: 0 0 1.6rem; }
  .ob-actions { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }

  .actions { display: flex; gap: 0.6rem; margin-bottom: 20px; flex-wrap: wrap; }

  .storage select { min-width: 240px; }
  .storage-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

  .list { display: flex; flex-direction: column; gap: 10px; }

  /* Anomaly panel */
  .anomaly-row {
    display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap;
    padding: 9px 0; border-bottom: 1px solid var(--card-border); font-size: 13.5px;
  }
  .anomaly-row:last-child { border-bottom: none; }
  .anomaly-row .when { color: var(--subtitle); font-size: 12px; margin-left: auto; }
  .anomaly-row .insight { flex-basis: 100%; color: var(--subtitle); font-size: 12.5px; }
  .sev { padding: 2px 9px; border-radius: 999px; font-size: 11px; font-weight: 600; text-transform: uppercase; }
  .sev.high   { background: #fdecea; color: #98211f; }
  .sev.medium { background: #fff4e5; color: #8a5300; }
  .sev.low    { background: #fff9db; color: #7a6a00; }
  .warn-text { color: #8a5300; font-size: 13px; }
  .conn {
    background: #fff;
    border-radius: 10px;
    border: 1px solid var(--card-border);
    padding: 14px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .conn-info { display: flex; flex-direction: column; gap: 4px; }
  .conn-provider { font-weight: 600; text-transform: capitalize; font-size: 13.5px; }
  .conn-email { font-size: 0.85rem; color: var(--subtitle); }
  .conn-buttons { display: flex; gap: 8px; }
  .conn-buttons .danger:hover { background: #fdecea; border-color: #c0392b; color: #c0392b; }
  pre {
    background: #14161f;
    color: #d4d4d4;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    font-size: 0.8rem;
    max-height: 320px;
    margin-top: 1.2rem;
  }

  /* Camera capture modal */
  #camera-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 100;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 16px;
  }
  #camera-modal video, #camera-modal canvas { max-width: 100%; max-height: 70vh; border-radius: 8px; background: #000; }
  .camera-controls { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
</style>
</head>
<body>
<%- include('partials/shell-open') %>
      <div class="page-head">
        <div>
          <h1>Dashboard</h1>
          <p class="subtitle">Connected mailboxes and invoice intake for your organization.</p>
        </div>
      </div>

      <!-- Onboarding: shown when the user has no connections yet -->
      <section id="onboarding" style="display:none">
        <h2 class="ob-title">Connect your mailboxes</h2>
        <p class="ob-text">Connect Gmail, Outlook, or both — we'll automatically find and file your invoices.</p>
        <div class="ob-actions">
          <button class="btn connect-btn" data-provider="google">Connect Gmail</button>
          <button class="btn connect-btn" data-provider="microsoft">Connect Outlook</button>
        </div>
      </section>

      <!-- Dashboard: shown once at least one mailbox is connected -->
      <section id="dashboard" style="display:none">
        <div class="actions">
          <button class="btn connect-btn" data-provider="google">Add Gmail mailbox</button>
          <button class="btn secondary connect-btn" data-provider="microsoft">Add Outlook mailbox</button>
          <a class="btn secondary" href="/voice">Voice invoice</a>
          <a class="btn secondary" href="/subscriptions">Subscriptions</a>
          <a class="btn secondary" href="/reports">Reports</a>
          <a class="btn secondary" href="/employees">Employees</a>
        </div>

        <!-- Where every invoice (Gmail or Outlook) is filed. OneDrive-only. -->
        <div class="card storage" id="storage" style="display:none">
          <h2>Invoice storage (OneDrive)</h2>
          <div class="storage-row">
            <select id="storage-select"></select>
            <button id="storage-save" class="btn" type="button">Save</button>
            <span class="ok-text" id="storage-status"></span>
          </div>
          <p class="muted-text" id="storage-hint" style="margin-top:10px"></p>
        </div>

        <!-- Manual invoice upload (PDF or image) -->
        <div class="card" id="uploadBox" style="display:none">
          <h2>Upload an invoice (PDF or image)</h2>
          <div class="storage-row">
            <input id="upload-input" type="file" accept="application/pdf,image/*" />
            <button id="upload-btn" class="btn" type="button">Upload &amp; extract</button>
            <button id="camera-btn" class="btn secondary" type="button">📷 Take photo</button>
            <span class="ok-text" id="upload-status"></span>
          </div>
          <p class="muted-text" style="margin-top:10px">Files are filed into your chosen OneDrive and the invoice fields are extracted automatically.</p>
          <p class="warn-text" id="upload-warning" style="display:none;margin-top:6px"></p>

          <!-- AI extraction review: prefilled from GPT-4o, editable, saved on Confirm only. -->
          <div id="upload-review" style="display:none">
            <h3>Review extracted invoice details — nothing is saved until you confirm</h3>
            <div class="form-row" style="margin-bottom:0.6rem">
              <div class="field"><label>Vendor</label><input id="ur-vendor" type="text" /></div>
              <div class="field"><label>Invoice number</label><input id="ur-number" type="text" /></div>
              <div class="field"><label>Amount</label><input id="ur-amount" type="number" min="0" step="0.01" /></div>
              <div class="field"><label>Currency</label><input id="ur-currency" class="cur" type="text" maxlength="3" /></div>
              <div class="field"><label>Category</label>
                <select id="ur-category">
                  <option value="software">software</option>
                  <option value="office_supplies">office_supplies</option>
                  <option value="travel">travel</option>
                  <option value="equipment">equipment</option>
                  <option value="utilities">utilities</option>
                  <option value="services">services</option>
                  <option value="other">other</option>
                </select>
              </div>
            </div>
            <div class="form-row" style="margin-bottom:0.8rem">
              <div class="field"><label>Invoice date</label><input id="ur-date" type="date" /></div>
              <div class="field"><label>Due date</label><input id="ur-due" type="date" /></div>
              <div class="field"><label>Tax amount</label><input id="ur-tax" type="number" min="0" step="0.01" /></div>
              <div class="field" style="flex:1; min-width:200px"><label>Description</label><input id="ur-description" type="text" /></div>
            </div>
            <div class="form-row">
              <button id="ur-confirm" class="btn" type="button">Confirm &amp; save</button>
              <button id="ur-cancel" class="btn secondary" type="button">Discard</button>
            </div>
            <p class="err-text" id="ur-err" style="display:none"></p>
          </div>
        </div>

        <!-- Recent spending anomalies (from anomaly_log via GET /anomalies) -->
        <div class="card" id="anomalyBox" style="display:none">
          <h2>⚠️ Spending anomalies</h2>
          <div id="anomaly-list"></div>
        </div>

        <!-- In-page camera capture: the photo goes through the same extract → review → confirm flow -->
        <div id="camera-modal" style="display:none">
          <video id="camera-video" autoplay playsinline muted></video>
          <canvas id="camera-canvas" style="display:none"></canvas>
          <div class="camera-controls">
            <button id="camera-capture" class="btn" type="button">📸 Capture</button>
            <button id="camera-use" class="btn" type="button" style="display:none">Use photo</button>
            <button id="camera-retake" class="btn secondary" type="button" style="display:none">Retake</button>
            <button id="camera-cancel" class="btn secondary" type="button">Cancel</button>
          </div>
        </div>

        <div class="list" id="list"></div>
        <pre id="output" style="display:none"></pre>
      </section>
<%- include('partials/shell-close') %>

  <script type="module" src="/js/app.js"></script>
</body>
</html>
