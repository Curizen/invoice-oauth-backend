<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head', { title: 'Sign in' }) %>
<style>
  html, body { height: 100%; }
  body {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem 1rem;
  }

  .stage {
    position: relative;
    width: 100%;
    max-width: 1080px;
    min-height: 640px;
    background: #f6f1e5;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(30, 24, 12, 0.08);
  }

  /* top bar */
  .topbar {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.6rem 2.4rem 0;
  }
  .brand-text span { display: block; font-family: var(--font-heading); font-weight: 700; font-size: 17px; line-height: 1.1; }
  .brand-text small { display: block; font-size: 11.5px; color: var(--subtitle); margin-top: 2px; }
  .brand-text small a { color: var(--subtitle); text-decoration: none; }
  .brand-text small a:hover { text-decoration: underline; }

  /* decorative background shapes */
  .deco { position: absolute; z-index: 1; }
  .deco.pattern-a {
    left: 6%; top: 40%; width: 110px; height: 110px; border-radius: 12px;
    background-image: radial-gradient(#1c1a17 2.5px, transparent 2.5px);
    background-size: 16px 16px; background-color: var(--accent); opacity: 0.85;
  }
  .deco.pattern-b {
    right: 8%; top: 27%; width: 90px; height: 130px; border-radius: 10px;
    background-image: radial-gradient(#1c1a17 2.5px, transparent 2.5px);
    background-size: 16px 16px; background-color: var(--accent); opacity: 0.85;
  }
  .deco.card-a { left: 12%; top: 58%; width: 110px; height: 80px; background: #fff; border: 1px solid var(--card-border); border-radius: 8px; }
  .deco.card-a::before, .deco.card-a::after {
    content: ''; position: absolute; left: 16px; right: 16px; height: 2px; background: var(--card-border);
  }
  .deco.card-a::before { top: 26px; }
  .deco.card-a::after { top: 38px; }
  .deco.card-b { right: 14%; top: 24%; width: 90px; height: 66px; background: #fff; border: 1px solid var(--card-border); border-radius: 8px; }
  .deco.card-b::before, .deco.card-b::after {
    content: ''; position: absolute; left: 14px; right: 14px; height: 2px; background: var(--card-border);
  }
  .deco.card-b::before { top: 20px; }
  .deco.card-b::after { top: 30px; }
  .deco.circle { width: 8px; height: 8px; border-radius: 50%; border: 1.5px solid #c9bfa8; }
  .deco.circle-a { left: 22%; top: 32%; }
  .deco.circle-b { right: 20%; top: 55%; }
  .deco.squiggle { width: 60px; height: 24px; opacity: 0.6; }
  .deco.squiggle-a { left: 15%; top: 33%; }
  .deco.squiggle-b { right: 24%; top: 63%; }
  .deco.arrow { left: 21%; top: 62%; width: 34px; height: 34px; opacity: 0.7; }

  .figure {
    position: absolute; z-index: 1; right: 5%; bottom: 0; width: 240px; height: auto;
    opacity: 0.95;
  }

  .ground-line {
    position: absolute; left: 0; right: 0; bottom: 78px; height: 1px; background: var(--card-border); z-index: 1;
  }

  /* card */
  .card {
    position: relative;
    z-index: 3;
    background: #fff;
    border: 1px solid var(--card-border);
    border-radius: 18px;
    padding: 2.2rem 2.4rem;
    width: 100%;
    max-width: 380px;
    margin: 4.5rem auto 0;
    box-shadow: 0 24px 48px rgba(30, 24, 12, 0.1);
  }
  h1 {
    font-size: 1.35rem; margin: 0 0 0.5rem; text-align: center;
    font-weight: 700; font-family: var(--font-heading);
  }
  .lede { text-align: center; color: var(--subtitle); font-size: 0.88rem; margin: 0 0 1.4rem; line-height: 1.4; }

  form { display: flex; flex-direction: column; gap: 0.55rem; }
  input {
    padding: 10px 12px;
    border: 1px solid #ddd3bf;
    border-radius: 10px;
    font-size: 0.95rem;
    font-family: var(--font-body);
  }
  input:focus { outline: 2px solid var(--accent); outline-offset: 0; }
  input.invalid { border-color: #b3261e; }
  button.primary {
    padding: 0.75rem 0.7rem;
    border: none;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: pointer;
    margin-top: 0.5rem;
  }
  button.primary:hover { background: var(--accent-dark); }
  button.primary:disabled { background: #d9d2c2; cursor: default; }
  .field-error {
    color: #b3261e;
    font-size: 0.78rem;
    min-height: 0.9em;
    margin: -0.25rem 0 0;
  }
  .form-error {
    color: #b3261e;
    font-size: 0.85rem;
    min-height: 0.9em;
  }

  .footer {
    position: relative; z-index: 3;
    text-align: center; font-size: 12px; color: var(--subtitle);
    padding: 1.4rem 1rem 1.8rem;
  }
  .footer a { color: var(--subtitle); }

  @media (max-width: 640px) {
    .card { margin-top: 3rem; padding: 1.6rem; }
    .figure, .deco { display: none; }
  }
</style>
</head>
<body>
  <div class="stage">
    <div class="topbar">
      <div class="brand-text">
        <span>Curizen Portal</span>
        <small><a href="mailto:support@curizen.io">support@curizen.io</a></small>
      </div>
    </div>

    <div class="ground-line"></div>
    <div class="deco pattern-a"></div>
    <div class="deco pattern-b"></div>
    <div class="deco card-a"></div>
    <div class="deco card-b"></div>
    <div class="deco circle circle-a"></div>
    <div class="deco circle circle-b"></div>
    <svg class="deco squiggle squiggle-a" viewBox="0 0 60 24" fill="none"><path d="M2 12c6-10 12 10 18 0s12-10 18 0 12 10 18 0" stroke="#c9bfa8" stroke-width="1.5"/></svg>
    <svg class="deco squiggle squiggle-b" viewBox="0 0 60 24" fill="none"><path d="M2 12c6-10 12 10 18 0s12-10 18 0 12 10 18 0" stroke="#c9bfa8" stroke-width="1.5"/></svg>
    <svg class="deco arrow" viewBox="0 0 34 34" fill="none"><path d="M8 26 26 8M14 8h12v12" stroke="#c9bfa8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    <svg class="figure" viewBox="0 0 200 260" fill="none">
      <rect x="50" y="200" width="70" height="55" rx="4" fill="#1c1a17"/>
      <circle cx="120" cy="70" r="26" fill="#1c1a17"/>
      <path d="M70 230c0-55 20-100 55-100s55 45 55 100" fill="#1c1a17"/>
      <path d="M40 150 L90 130 L95 150 L48 172 Z" fill="var(--accent)"/>
    </svg>

    <div class="card">
      <h1>Sign in</h1>
      <p class="lede">Enter your email and password to access the Curizen Portal.</p>

      <form id="signin-form" novalidate>
        <input type="email" id="si-email" placeholder="Email" autocomplete="email" />
        <div class="field-error" id="si-email-err"></div>
        <input type="password" id="si-password" placeholder="Password" autocomplete="current-password" />
        <div class="field-error" id="si-password-err"></div>
        <div class="form-error" id="si-error"></div>
        <button class="primary" type="submit" id="si-submit">Sign in</button>
      </form>
    </div>

    <div class="footer">© Curizen Portal 2026</div>
  </div>

  <script type="module" src="/js/login.js"></script>
</body>
</html>
